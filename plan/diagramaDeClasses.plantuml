@startuml diagramaDeClasses

' =========================
' Classe base (sem herança explícita)
' =========================
abstract class DefaultEntity <<MappedSuperclass>> {
  -id: Long
  -dataCadastro: LocalDateTime
}

note bottom of DefaultEntity
  Todas as classes herdam
  de DefaultEntity
end note

' =========================
' ENUM
' =========================

enum UnidadeMedida {
  KG
  GRAMA
  LITRO
  MILILITRO
  UNIDADE
}

' =========================
' ENTIDADES PRINCIPAIS (CRUDs)
' =========================
class Pamonha {
  -nome: String
  -descricao: String
  -preco: BigDecimal
  -estoque: int
}

class Ingrediente {
  -nome: String
  -precoUnitario: BigDecimal
  -estoque: double
}

class Categoria {
  -nome: String
  -descricao: String
}

class ModoPreparo {
  -descricao: String
  -tempoPreparoMinutos: int
}

' =========================
' HERANÇA (EMBALAGEM)
' =========================
abstract class Embalagem {
  -descricao: String
  -custo: BigDecimal
  -pesoSuportado: double
}

class EmbalagemPlastica {
  -tipoPlastico: String
  -reciclavel: boolean
}

class EmbalagemBiodegradavel {
  -material: String
  -tempoDecomposicaoDias: int
}

Embalagem <|-- EmbalagemPlastica
Embalagem <|-- EmbalagemBiodegradavel

' =========================
' COMPOSIÇÃO
' =========================
class TabelaNutricional {
  -valorEnergetico: double
  -carboidratos: double
  -proteinas: double
  -gordurasTotais: double
  -fibras: double
  -sodio: double
}

Pamonha "1" *-- "1" TabelaNutricional

class ItemReceita {
  -quantidade: double
}

Pamonha "1" *-- "1..*" ItemReceita

' =========================
' RELACIONAMENTOS
' =========================

' N:1
ItemReceita "* " --> "1" Ingrediente

' N:N (AGREGAÇÃO)
Pamonha "* " o-- "* " Categoria

' Associação
Pamonha "* " --> "1" Embalagem

' Composição (mais coerente)
Pamonha "1" *-- "1" ModoPreparo

' Enum
ItemReceita "* " --> "1" UnidadeMedida
Ingrediente "* " --> "1" UnidadeMedida

@enduml